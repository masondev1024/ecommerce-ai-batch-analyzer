AIRFLOW_UID=50000

# Optional: override Fernet key for encrypting Connections/Variables (default is in docker-compose.yaml)
# AIRFLOW__FERNET_KEY=

# Airflow scheduler calls the API by Docker service name — not localhost (see docker-compose REVIEW_API_BASE_URL).
# REVIEW_API_BASE_URL=http://ai-api-server:8000

# FastAPI (ai-api-server) reads this inside the container. Host-only `export` is NOT passed in.
# Get a key: https://aistudio.google.com/app/apikey — then save this file and run:
#   docker compose up -d --build ai-api-server
GEMINI_API_KEY="AIzaSyAnWBNj3QAqtPPl__sKT0XozTw8Rsmbqtg"

